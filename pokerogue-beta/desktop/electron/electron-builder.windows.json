  },
  "extraMetadata": {
    "main": "desktop/electron/main.cjs",
    "description": "PokeRogue 2P desktop build",
    "author": "SolVolrund",
    "dependencies": {},
    "devDependencies": {},
    "optionalDependencies": {}
  },
  "files": [
    "desktop/electron/main.cjs",
    "dist/**/*",
    "scripts/two-player-ws-relay.mjs",
    "app-icon.png",
    "package.json"
  ],
  "win": {
